# Copy to .env and adjust. .env is git-ignored.
PORT=3001
# MUST be a long random string in production — the server refuses to boot in
# production without it. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# Defaults to server/data/cyber.db when unset. In production point this at a
# persistent disk, e.g. /var/data/cyber.db
DB_PATH=
